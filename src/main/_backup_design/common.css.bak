@charset "UTF-8";
@import url('https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600&display=swap');

/* ===== 기본 초기화 ===== */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* 공통 콘텐츠 너비 (80% 중앙 정렬) */
.main-wrapper {
    width: 80%;
    margin: 0 auto;
}

/* 전역 테이블 기본 스타일 (각 페이지에서 border: none 으로 오버라이드해서 사용) */
table, td, th {
    border: 1px solid black;
}

table {
    border-collapse: collapse;
}

/* 리스트 불릿 제거 */
ul, li { list-style: none; }


/* ===== 네비바 ===== */
.navbar {
    width: 100%;
    background-color: #1a3d1a;
    height: 80px;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 2px solid #FFD700;
}

/* 우측 장식 패턴 */
.navbar::after {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 220px; height: 100%;
    background: repeating-linear-gradient(
        45deg,
        transparent, transparent 6px,
        rgba(255, 215, 0, 0.05) 6px, rgba(255, 215, 0, 0.05) 12px
    );
    pointer-events: none;
}

/* 네비바 내부 레이아웃 (로고 / 메뉴 / 로그인 3분할, 메뉴는 absolute 중앙 정렬) */
.navbar-inner {
    width: 100%;
    padding: 0 48px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-sizing: border-box;
    position: relative;
}

/* 로고 + SBN 텍스트 묶음 */
.navbar-brand {
    display: flex;
    align-items: center;
    color: #FFD700;
    font-family: 'Oswald', sans-serif;
    font-size: 33px;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 8px;
    padding: 15px;
    transition: color 0.2s;
}

.navbar-brand:hover {
    color: #ffe566;
}

/* 로고 이미지 */
.navbar-logo {
    height: 66px;
    width: auto;
    padding-top: 5px;
    margin-right: -13px;
}

/* 메뉴 (선수, 팀, 리그, 게시판) - absolute 로 중앙 고정 */
.navbar-menu {
    display: flex;
    gap: 36px;
    position: absolute;
    left: 50%;
    transform: translateX(calc(-63% + 20px)); /* home.jsp 네비바와 정렬 맞춤 */
}

/* 메뉴 링크 - 호버 시 슬라이드 언더라인 */
.navbar-menu a {
    position: relative;
    font-family: 'Oswald', sans-serif;
    color: #ffffff;
    text-decoration: none;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 1px;
    padding-bottom: 4px;
    transition: color 0.2s;
}

.navbar-menu a::after {
    content: '';
    position: absolute;
    bottom: 0; left: 50%;
    width: 0; height: 2px;
    background: #FFD700;
    transform: translateX(-50%);
    transition: width 0.22s ease;
}

.navbar-menu a:hover {
    color: #FFD700;
}

.navbar-menu a:hover::after {
    width: 100%;
}

/* 로그인 / 로그아웃 영역 */
.navbar-auth {
    display: flex;
    gap: 12px;
    align-items: center;
    z-index: 1;
}

/* 로그인 상태 - 회원 이름 텍스트 */
.navbar-auth span {
    font-family: 'Oswald', sans-serif;
    color: rgba(255, 255, 255, 0.65);
    font-size: 13px;
    letter-spacing: 0.5px;
}

/* 로그아웃 / 마이페이지 링크 */
.navbar-auth a {
    font-family: 'Oswald', sans-serif;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.5px;
    transition: color 0.2s;
}

.navbar-auth a:hover {
    color: #FFD700;
}

/* 로그인 버튼 - 골드 테두리 */
.navbar-auth .btn-login {
    border: 1.5px solid #FFD700;
    color: #FFD700 !important;
    padding: 5px 18px;
    border-radius: 3px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1px;
    transition: background 0.18s, color 0.18s;
}

.navbar-auth .btn-login:hover {
    background: #FFD700;
    color: #1a3d1a !important;
}

/* 마이페이지 버튼 색상 */
.navbar-auth .btn-mypage {
    color: rgba(255, 215, 0, 0.75) !important;
}

.navbar-auth .btn-mypage:hover {
    color: #FFD700 !important;
}


/* ===== 푸터 ===== */
.footer {
    width: 100%;
    background-color: #1a3d1a;
    border-top: 3px solid #FFD700;
    padding: 40px 0 30px;
    margin-top: 0;
}

/* 푸터 내부 - 중앙 정렬 3행 구조 */
.footer-inner {
    max-width: 1160px;
    margin: 0 auto;
    text-align: center;
    padding: 0 32px;
}

/* SBN 브랜드 텍스트 */
.footer-brand {
    font-family: 'Oswald', sans-serif;
    font-size: 24px;
    font-weight: 700;
    color: #FFD700;
    letter-spacing: 10px;
    margin-bottom: 14px;
}

/* 내부 링크 */
.footer-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
}

.footer-nav a {
    font-family: 'Oswald', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    letter-spacing: 0.5px;
    transition: color 0.15s;
}

.footer-nav a:hover {
    color: #FFD700;
}

.footer-nav .footer-dot {
    color: rgba(255, 215, 0, 0.35);
    font-size: 14px;
    line-height: 1;
}

/* 저작권 */
.footer-copy {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.3px;
}
